    { "key": "destAccountId", "value": "22222222-2222-2222-2222-222222222222", "type": "string" },
    { "key": "createdAccountId", "value": "", "type": "string" },
    { "key": "idempotencyKey", "value": "demo-key-001", "type": "string" }
