              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('retornou id', () => pm.expect(body.id).to.be.a('string'));",
                  "pm.collectionVariables.set('createdAccountId', body.id);",
                  "pm.test('saldo correto', () => pm.expect(Number(body.balance)).to.eql(300));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/v1/accounts", "host": ["{{baseUrl}}"], "path": ["api","v1","accounts"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Carlos Lima\",\n  \"initialBalance\": 300.00\n}"
            }
